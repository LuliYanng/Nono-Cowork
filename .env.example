# ============================
# Nono Agent Configuration
# Copy this file to .env and fill in your keys
# ============================

# === LLM Config ===
# Method 1: Use LiteLLM native provider prefix (recommended for supported providers)
#   MODEL=dashscope/qwen3.5-plus        (Alibaba DashScope)
#   MODEL=gemini/gemini-2.5-flash       (Google Gemini)
#   MODEL=anthropic/claude-sonnet-4-20250514   (Anthropic Claude)
#   MODEL=deepseek/deepseek-chat        (DeepSeek)
#
# Method 2: Use any OpenAI-compatible API (DashScope Bailian, Ollama, vLLM, etc.)
#   MODEL=qwen3.5-plus-2026-02-15       (model name without prefix)
#   API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
#   API_KEY=sk-xxx
MODEL=
API_BASE=
API_KEY=

# === Provider API Keys (for Method 1, fill in the one you need) ===
# Alibaba Cloud DashScope (Qwen): https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Anthropic Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# === Telegram Bot (optional) ===
# Search @BotFather in Telegram → /newbot to create a bot and get a Token
TELEGRAM_BOT_TOKEN=
# Restrict allowed Telegram user IDs (numeric, comma-separated, leave empty for unrestricted)
TELEGRAM_ALLOWED_USERS=
# Owner's Telegram chat_id for notification delivery (auto-detected from ALLOWED_USERS if not set)
TELEGRAM_OWNER_CHAT_ID=

# === Feishu Bot (optional) ===
# Create an enterprise app on Feishu Open Platform to get these credentials
# See docs/feishu_setup.md for details
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Restrict allowed user open_ids (comma-separated, leave empty for unrestricted)
FEISHU_ALLOWED_USERS=
# Owner's Feishu open_id for notification delivery (auto-detected from ALLOWED_USERS if not set)
FEISHU_OWNER_OPEN_ID=

# === Syncthing File Sync (optional) ===
SYNCTHING_API_KEY=

# === Workspace Directory ===
# The Agent's default working directory. If not set, it auto-detects
# from Syncthing's first synced folder, or falls back to ~/
WORKSPACE_DIR=

# === Composio Tool Integration (optional) ===
# Composio provides 1000+ pre-built tool integrations (Gmail, Slack, etc.)
# with OAuth management. Get your API key at https://app.composio.dev/
COMPOSIO_API_KEY=
# User ID for Composio sessions (default: "default")
COMPOSIO_USER_ID=
# How long to wait for the user to complete OAuth authorization (seconds, default: 300)
COMPOSIO_AUTH_WAIT_TIMEOUT=300

# === Webhook / Trigger Config (optional) ===
# Port for the webhook HTTP server (used by Composio triggers)
WEBHOOK_PORT=9090
# Public hostname or IP of this server (for webhook URL generation)
SERVER_HOST=

# === Multi-Channel ===
# Unified user identity. All authenticated users across all channels
# share the same session under this ID. This enables seamless cross-channel
# context sharing (e.g., start a task on Desktop, continue on Telegram).
OWNER_USER_ID=owner

# Which channels to start (comma-separated). Used by main.py unified entry point.
# Available: desktop, feishu, telegram
CHANNELS=desktop

# Desktop channel HTTP port
DESKTOP_PORT=8080
# Desktop channel API token (leave empty to disable auth)
DESKTOP_API_TOKEN=
